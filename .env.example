# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. Never commit secrets.

# Public — used in the browser. Keep Mapbox here.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Server-only — used by /api/chat. Never expose to the client.
OPENAI_API_KEY=

# Server-only — used by /api/lead to email captured chatbot leads to Anu.
# Sign up at https://resend.com, create an API key, paste here.
RESEND_API_KEY=
# Optional overrides (defaults: from = onboarding@resend.dev, to = anu@statdoctor.net)
# Once you verify statdoctor.app in Resend, change LEAD_EMAIL_FROM to e.g.
# "StatDoctor Bot <bot@statdoctor.app>" so emails come from your domain.
# LEAD_EMAIL_FROM="StatDoctor Bot <bot@statdoctor.app>"
# LEAD_EMAIL_TO="anu@statdoctor.net"
